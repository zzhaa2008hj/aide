#!/usr/bin/env bash
# pre-push hook — Enforce marketplace.json AND plugin.json version bump
# when functional files change.
#
# Rules (matches bump-version.sh):
#   Same branch (master/main) → patch bump required (x.y.Z)
#   Feature branch            → minor bump required (x.Y.z)
#   --major flag              → major bump required (X.y.z, manual)
#
# Install: ln -sf ../../hooks/pre-push .git/hooks/pre-push

set -euo pipefail

REMOTE="$1"
REMOTE_URL="$2"

# Tracked functional paths (changes here require version bump)
FUNCTIONAL_PATHS=("skills/" "aide-core/" "templates/" "hooks/")

# Detect default branch
DEFAULT_BRANCH=$(git remote show origin 2>/dev/null | grep -E 'HEAD (branch|分支)' | awk '{print $NF}' || true)
[ -z "$DEFAULT_BRANCH" ] && DEFAULT_BRANCH="master"

while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    BRANCH=$(git rev-parse --abbrev-ref HEAD)

    if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
        BASE=$(git merge-base "$DEFAULT_BRANCH" HEAD 2>/dev/null || echo "")
        [ -z "$BASE" ] && continue
        RANGE="$BASE..$LOCAL_SHA"
    else
        RANGE="$REMOTE_SHA..$LOCAL_SHA"
    fi

    CHANGED=$(git diff --name-only "$RANGE" 2>/dev/null || echo "")
    [ -z "$CHANGED" ] && continue

    FUNC_CHANGED=false
    for path in "${FUNCTIONAL_PATHS[@]}"; do
        if echo "$CHANGED" | grep -q "^$path"; then
            FUNC_CHANGED=true
            break
        fi
    done

    [ "$FUNC_CHANGED" = false ] && continue

    # Check both marketplace.json AND plugin.json were changed
    MP_CHANGED=$(echo "$CHANGED" | grep -c '^.claude-plugin/marketplace.json' || true)
    PLUGIN_CHANGED=$(echo "$CHANGED" | grep -c '^.claude-plugin/plugin.json' || true)

    if [ "$MP_CHANGED" -eq 0 ] || [ "$PLUGIN_CHANGED" -eq 0 ]; then
        MISSING=""
        [ "$MP_CHANGED" -eq 0 ] && MISSING="marketplace.json"
        [ "$PLUGIN_CHANGED" -eq 0 ] && MISSING="$MISSING${MISSING:+, }plugin.json"
        cat <<EOF

============================================================
  PUSH BLOCKED: Functional files changed without version bump
============================================================

Changed files in: skills/, aide-core/, templates/, or hooks/

Missing version bump in: $MISSING

Run:

  bash aide-core/scripts/bump-version.sh

  Branch: $BRANCH → $( [ "$BRANCH" != "$DEFAULT_BRANCH" ] && echo "minor bump" || echo "patch bump" )
  (use --major for breaking changes)

Then commit and push again.

============================================================

EOF
        exit 1
    fi

    # Verify version actually bumped in both files
    OLD_MP_VERSION=$(git show "$REMOTE_SHA":.claude-plugin/marketplace.json 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['plugins'][0]['version'])" 2>/dev/null || echo "0.0.0")
    NEW_MP_VERSION=$(git show "$LOCAL_SHA":.claude-plugin/marketplace.json 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['plugins'][0]['version'])" 2>/dev/null || echo "")
    OLD_PLUGIN_VERSION=$(git show "$REMOTE_SHA":.claude-plugin/plugin.json 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['version'])" 2>/dev/null || echo "0.0.0")
    NEW_PLUGIN_VERSION=$(git show "$LOCAL_SHA":.claude-plugin/plugin.json 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['version'])" 2>/dev/null || echo "")

    VERSION_MISMATCH=false
    [ "$OLD_MP_VERSION" = "$NEW_MP_VERSION" ] && VERSION_MISMATCH=true
    [ "$OLD_PLUGIN_VERSION" = "$NEW_PLUGIN_VERSION" ] && VERSION_MISMATCH=true
    [ "$NEW_MP_VERSION" != "$NEW_PLUGIN_VERSION" ] && VERSION_MISMATCH=true

    if [ "$VERSION_MISMATCH" = true ]; then
        cat <<EOF

============================================================
  PUSH BLOCKED: Version inconsistency detected
============================================================

marketplace.json: $OLD_MP_VERSION → $NEW_MP_VERSION
plugin.json:      $OLD_PLUGIN_VERSION → $NEW_PLUGIN_VERSION

Both files must be updated to the SAME new version. Run:

  bash aide-core/scripts/bump-version.sh

  Branch: $BRANCH → $( [ "$BRANCH" != "$DEFAULT_BRANCH" ] && echo "minor bump" || echo "patch bump" )

Then commit and push again.

============================================================

EOF
        exit 1
    fi

    echo "✓ Version check passed: $OLD_PLUGIN_VERSION → $NEW_PLUGIN_VERSION ($BRANCH)"
    echo "  marketplace.json + plugin.json in sync"
done

exit 0
