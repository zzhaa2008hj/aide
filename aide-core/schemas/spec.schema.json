{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aide.dev/schemas/spec.schema.json",
  "title": "Specification Output",
  "description": "Schema for the structured output of the spec stage (aide-spec skill).",
  "type": "object",
  "required": ["schema_version", "features", "constraints", "scope_boundary"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Schema version for forward-compatibility. Currently '1'."
    },
    "features": {
      "type": "array",
      "description": "List of features extracted or refined from requirements.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptance_criteria"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F\\d{3}$",
            "description": "Feature ID, e.g., F001, F002."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Short summary of the feature."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Detailed description of the feature."
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Verifiable acceptance criteria for this feature."
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "description": "Technical or business constraints that apply to the whole spec.",
      "items": { "type": "string" }
    },
    "scope_boundary": {
      "type": "string",
      "description": "What is explicitly out of scope. Prevents scope creep."
    }
  },
  "additionalProperties": false
}
